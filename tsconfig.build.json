    "compilerOptions": {
        "noEmit": false,
        "rootDir": "src",
        "outDir": "dist",
        "declaration": true,
        "declarationMap": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["tests/**", "node_modules"]
}
